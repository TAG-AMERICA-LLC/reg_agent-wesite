---
interface Props {
  href: string;
  category: string;
  title: string;
  excerpt: string;
  date?: string;
  readingTime?: string;
  gradient?: string;
  index?: number;
}
const { href, category, title, excerpt, date, readingTime, index = 0 } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---
<a href={href} class="group block py-8 relative" style="border-top: 1px solid rgb(var(--hairline));">
  <div class="grid grid-cols-12 gap-6 items-baseline">
    <div class="col-span-2 md:col-span-1 chapter">— {num}</div>
    <div class="col-span-8 md:col-span-2">
      <span class="chip">{category}</span>
    </div>
    <div class="col-span-12 md:col-span-7">
      <h3 class="font-serif text-2xl md:text-3xl leading-[1.15] text-ink"
        style="font-variation-settings: 'SOFT' 35, 'opsz' 72;">
        <span class="link-underline">{title}</span>
      </h3>
      <p class="mt-3 text-[15px] text-ink-soft leading-relaxed max-w-2xl">{excerpt}</p>
    </div>
    <div class="col-span-12 md:col-span-2 md:text-right">
      <div class="text-[12.5px] text-ink-mute">{date}</div>
      {readingTime && <div class="text-[12px] text-ink-faint mt-1">{readingTime}</div>}
    </div>
  </div>
  <span class="absolute right-0 top-8 inline-flex h-9 w-9 items-center justify-center rounded-full opacity-0 group-hover:opacity-100 transition-all"
    style="background: rgb(var(--ink)); color: rgb(var(--paper));">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
  </span>
</a>
