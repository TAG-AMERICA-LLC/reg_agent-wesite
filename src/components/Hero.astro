---
import Reveal from './Reveal.astro';
---

<section class="relative overflow-hidden grain glow-paper">
  <div class="container-x relative pt-16 md:pt-24 pb-20 md:pb-28">

    <!-- Top meta strip -->
    <Reveal>
      <div class="flex items-center justify-between gap-6 flex-wrap mb-12 md:mb-20">
        <div class="flex items-center gap-3 text-[12.5px] text-ink-mute">
          <span class="inline-flex h-2 w-2 rounded-full bg-clay animate-pulse" aria-hidden="true"></span>
          <span>Portale informativo · Servizio amministrativo</span>
        </div>
        <div class="flex items-center gap-2 text-[12.5px] text-ink-mute">
          <span>Italia</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          <span class="text-ink font-medium">Florida</span>
        </div>
      </div>
    </Reveal>

    <!-- Monumental headline -->
    <Reveal delay={120}>
      <h1 class="display max-w-[18ch]">
        Apri la tua company<br/>in <em>Florida</em>,<br/>dall'Italia.
      </h1>
    </Reveal>

    <!-- Bottom row: lead + meta sidebar -->
    <div class="grid grid-cols-12 gap-8 mt-16 md:mt-24 items-end">
      <Reveal delay={220} class="col-span-12 md:col-span-7 lg:col-span-6">
        <p class="text-[19px] md:text-[21px] leading-[1.55] text-ink-soft max-w-xl">
          Un servizio amministrativo end-to-end per imprenditori italiani.
          Filing e registered agent gestiti da un <span class="text-ink font-medium">partner in Florida</span>.
          Comunicazione in italiano, ruoli chiari, nessuna sorpresa.
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contatti/" class="btn btn-primary btn-arrow px-6 py-3.5">
            Richiedi informazioni
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="/come-funziona/" class="btn btn-outline px-6 py-3.5">Vedi come funziona</a>
        </div>
      </Reveal>

      <!-- Asymmetric stat -->
      <Reveal delay={320} class="col-span-12 md:col-span-5 lg:col-start-9 lg:col-span-4">
        <div class="spotlight-stat">
          <div class="num"><em>5</em> step</div>
          <p class="lbl">Dal primo contatto alla consegna dei documenti societari, in pochi passaggi tracciati.</p>
          <a href="/come-funziona/" class="mt-5 inline-flex items-center gap-1.5 text-[13px] text-ink link-line">
            Vedi il processo
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </Reveal>
    </div>
  </div>

  <!-- Big watermark "Florida" sotto l'hero, raffinato -->
  <div class="container-x relative pb-10 md:pb-16 overflow-hidden" aria-hidden="true">
    <div class="select-none pointer-events-none flex items-baseline gap-6"
      style="font-family: 'Fraunces Variable', serif; font-size: clamp(4rem, 14vw, 12rem); line-height: 0.85; letter-spacing: -0.05em; font-variation-settings: 'SOFT' 30, 'opsz' 144;">
      <span style="color: rgb(var(--ink) / 0.04); font-style: italic;">Filed in</span>
      <span class="text-clay-deep" style="color: rgb(var(--clay) / 0.18); font-variation-settings: 'SOFT' 100, 'WONK' 1, 'opsz' 144; font-style: italic;">Florida</span>
      <span style="color: rgb(var(--ink) / 0.04);">.</span>
    </div>
  </div>
</section>
