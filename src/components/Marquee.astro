---
const items = [
  'Milano',
  'Miami',
  'Florida',
  'Sunbiz filing',
  'Registered Agent',
  '<em>Italian</em>',
  'EIN',
  'Operating Agreement',
  'LLC',
  'C-Corporation',
];
const cycle = [...items, ...items];
---

<div class="marquee">
  <div class="marquee-track" aria-hidden="true">
    {cycle.map((it) => (
      <span class="marquee-item" set:html={it} />
    ))}
  </div>
</div>
