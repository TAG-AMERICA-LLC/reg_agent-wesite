---
import ThemeToggle from './ThemeToggle.tsx';
const pathname = Astro.url.pathname;

const nav = [
  { label: 'Servizio', href: '/company-setup-florida/', children: [
    { label: 'Panoramica', href: '/company-setup-florida/', desc: 'Cosa facciamo, cosa non facciamo.' },
    { label: 'LLC in Florida', href: '/company-setup-florida/llc/', desc: 'Struttura snella e flessibile.' },
    { label: 'Corporation in Florida', href: '/company-setup-florida/corporation/', desc: 'Per progetti strutturati.' },
    { label: 'Pacchetti & prezzi', href: '/company-setup-florida/pacchetti/', desc: 'Tre opzioni chiare.' },
  ]},
  { label: 'Il processo', href: '/come-funziona/' },
  { label: 'Partner', href: '/registered-agent/' },
  { label: 'Editoriale', href: '/business-in-florida/' },
  { label: 'Manifesto', href: '/manifesto/' },
];

const isActive = (href: string) => pathname === href || (href !== '/' && pathname.startsWith(href));
---

<header class="sticky top-0 z-50">
  <div class="absolute inset-0 backdrop-blur-xl"
    style="background: rgb(var(--paper) / 0.78); border-bottom: 1px solid rgb(var(--hairline));"></div>

  <div class="relative container-x flex items-center justify-between" style="height: 80px;">
    <!-- Brand -->
    <a href="/" class="group flex items-center gap-3" aria-label="[NOME BRAND] – Home">
      <span class="logomark group-hover:scale-105 transition-transform">F</span>
      <span class="font-serif text-[17px]" style="font-variation-settings: 'opsz' 18, 'SOFT' 40;">[NOME BRAND]</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-7" aria-label="Navigazione">
      {nav.map((item) => (
        item.children ? (
          <div class="group relative">
            <a href={item.href}
              class={`inline-flex items-center gap-1 text-[14px] transition-colors ${isActive(item.href) ? 'text-ink' : 'text-ink-soft hover:text-ink'}`}>
              {item.label}
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:rotate-180" style="transition-duration: 0.3s;">
                <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
            <!-- Mega menu -->
            <div class="invisible absolute left-0 top-full pt-3 opacity-0 transition-all duration-300 group-hover:visible group-hover:opacity-100">
              <div class="rounded-2xl p-2.5 min-w-[340px]"
                style="background: rgb(var(--paper-soft)); box-shadow: 0 20px 60px rgb(var(--ink) / 0.10), inset 0 0 0 1px rgb(var(--hairline));">
                {item.children.map((c) => (
                  <a href={c.href} class="group/item block rounded-xl p-3 transition-colors hover:bg-paper-deep">
                    <div class="flex justify-between items-start gap-3">
                      <div>
                        <div class={`text-[14.5px] font-medium ${isActive(c.href) ? 'text-clay-deep' : 'text-ink'}`}>{c.label}</div>
                        <div class="text-[12.5px] text-ink-mute mt-0.5">{c.desc}</div>
                      </div>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-ink-faint opacity-0 group-hover/item:opacity-100 group-hover/item:translate-x-0.5 transition-all"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href}
            class={`text-[14px] transition-colors ${isActive(item.href) ? 'text-ink' : 'text-ink-soft hover:text-ink'}`}>
            {item.label}
          </a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-2.5">
      <ThemeToggle client:load />
      <a href="/contatti/" class="hidden sm:inline-flex btn btn-primary text-[13px] py-2.5 px-4 btn-arrow">
        Richiedi informazioni
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <button id="mobile-toggle" aria-label="Apri menu"
        class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-full"
        style="box-shadow: inset 0 0 0 1px rgb(var(--hairline-hard));">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="13" x2="20" y2="13"/><line x1="4" y1="19" x2="20" y2="19"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden relative" style="background: rgb(var(--paper)); border-top: 1px solid rgb(var(--hairline));">
    <div class="container-x py-6 flex flex-col gap-1">
      {nav.map((item) => (
        <a href={item.href} class={`py-2.5 text-[16px] ${isActive(item.href) ? 'text-clay-deep font-medium' : 'text-ink'}`}>{item.label}</a>
      ))}
      <a href="/contatti/" class="btn btn-primary mt-4 justify-center">Richiedi informazioni</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
