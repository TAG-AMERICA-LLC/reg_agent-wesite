---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';
---

<Layout title="Richiesta ricevuta | [NOME BRAND]" description="Conferma invio richiesta." noindex={true}>
  <section class="py-32 md:py-40">
    <div class="container-x text-center max-w-2xl mx-auto">
      <Reveal>
        <div class="mx-auto inline-flex h-20 w-20 items-center justify-center rounded-full"
          style="background: rgb(var(--accent-soft)); color: rgb(var(--accent-deep));">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h1 class="display mt-8">Richiesta <em>ricevuta</em>.</h1>
        <p class="mt-6 text-soft text-[18px] leading-relaxed max-w-lg mx-auto">
          Grazie. Abbiamo ricevuto la tua richiesta e ti risponderemo entro <strong style="color: rgb(var(--ink-900));">[N] giorni lavorativi</strong> all'indirizzo email indicato.
        </p>
        <div class="mt-10 flex justify-center gap-3 flex-wrap">
          <a href="/business-in-florida/" class="btn btn-primary px-6 py-3">Leggi gli articoli</a>
          <a href="/faq/" class="btn btn-outline px-6 py-3">Consulta le FAQ</a>
        </div>
      </Reveal>

      <Reveal delay={250} class="mt-16">
        <div class="rounded-3xl p-7 text-left" style="background: rgb(var(--surface)); border: 1px solid rgb(var(--line));">
          <h3 class="font-serif text-xl mb-4">Nel frattempo</h3>
          <ul class="space-y-3">
            {[
              'Riceverai una mail di conferma con i prossimi passi.',
              'Se non la trovi, controlla la cartella spam/promozioni.',
              'Per richieste urgenti scrivici a [EMAIL].',
            ].map((it) => (
              <li class="flex items-start gap-3 text-soft text-[15px]">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="color: rgb(var(--accent)); flex-shrink: 0; margin-top: 4px;"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{it}</span>
              </li>
            ))}
          </ul>
        </div>
      </Reveal>
    </div>
  </section>
</Layout>
