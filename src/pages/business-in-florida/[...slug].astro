---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await post.render();

const all = (await getCollection('blog')).filter((p) => p.slug !== post.slug);
const related = all.slice(0, 3);

const formatDate = (d: Date) =>
  new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
---

<Layout title={`${post.data.title} | [NOME BRAND]`} description={post.data.description}>

  <article class="pt-20 pb-12 md:pt-28">
    <div class="container-x max-w-readable">
      <nav class="text-[13px] text-muted mb-8">
        <a href="/" class="link-underline">Home</a> <span class="mx-2">/</span>
        <a href="/business-in-florida/" class="link-underline">Editoriale</a> <span class="mx-2">/</span>
        <span>{post.data.category}</span>
      </nav>

      <Reveal>
        <span class="tag tag-dot">{post.data.category}</span>
        <h1 class="display mt-7" style="font-size: clamp(2rem, 4.5vw, 3.4rem);">{post.data.title}</h1>
        <div class="mt-6 text-[14px] text-muted">{formatDate(post.data.publishedAt)} · Lettura {post.data.readingTime}</div>
      </Reveal>
    </div>
  </article>

  <section class="pb-24">
    <div class="container-x max-w-readable prose-editorial dropcap">
      <Content />
    </div>
  </section>

  <section class="pb-24">
    <div class="container-x max-w-readable">
      <Reveal>
        <div class="rounded-3xl p-8 md:p-10 flex flex-col md:flex-row items-start md:items-center gap-6"
          style="background: rgb(var(--surface)); border: 1px solid rgb(var(--line));">
          <div class="flex-1">
            <strong class="font-serif text-2xl">Hai bisogno del servizio di company setup?</strong>
            <p class="mt-2 text-soft">Ti aiutiamo nella parte amministrativa, con il nostro partner Florida.</p>
          </div>
          <a href="/contatti/" class="btn btn-primary flex-shrink-0">
            Richiedi informazioni
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </Reveal>
    </div>
  </section>

  {related.length > 0 && (
    <section class="pb-24" style="background: rgb(var(--surface));">
      <div class="container-x py-24">
        <Reveal class="mb-12">
          <span class="eyebrow">Articoli correlati</span>
          <h2 class="display-sm mt-5">Continua a leggere.</h2>
        </Reveal>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          {related.map((r, i) => (
            <Reveal delay={i * 120}>
              <ArticleCard
                href={`/business-in-florida/${r.slug}/`}
                category={r.data.category}
                title={r.data.title}
                excerpt={r.data.description}
                date={formatDate(r.data.publishedAt)}
                readingTime={r.data.readingTime}
                gradient={r.data.gradient}
              />
            </Reveal>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
