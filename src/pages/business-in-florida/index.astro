---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const categories = ['Tutti', 'LLC', 'Corporation', 'Registered Agent', 'Documenti', 'Tips', 'News'];

const formatDate = (d: Date) =>
  new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
---

<Layout
  title="Business in Florida – News e Guide | [NOME BRAND]"
  description="Approfondimenti informativi su LLC, Corporation, registered agent e adempimenti in Florida. Aggiornamenti regolari, contenuti non consulenziali.">

  <section class="pt-20 pb-12 md:pt-28">
    <div class="container-x">
      <nav class="text-[13px] text-muted mb-8">
        <a href="/" class="link-underline">Home</a> <span class="mx-2">/</span> <span>Editoriale</span>
      </nav>
      <Reveal>
        <span class="eyebrow">Editoriale</span>
        <h1 class="display mt-7 max-w-3xl">Business in <em>Florida</em>.</h1>
      </Reveal>
      <Reveal delay={150} class="mt-8 max-w-2xl text-soft text-[18px] leading-relaxed">
        <p>
          Approfondimenti, news e checklist su come funziona il business in Florida.
          Tutti i contenuti sono <strong style="color: rgb(var(--ink-900));">informativi</strong> e non costituiscono consulenza legale, fiscale o contabile.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="pb-8">
    <div class="container-x">
      <Reveal delay={50}>
        <div class="flex gap-2 flex-wrap">
          {categories.map((c, i) => (
            <button class={`tag transition-colors ${i === 0 ? '' : 'hover:bg-surface'}`}
              style={i === 0 ? 'background: rgb(var(--ink-900)); color: rgb(var(--bg)); border-color: rgb(var(--ink-900));' : ''}>
              {c}
            </button>
          ))}
        </div>
      </Reveal>
    </div>
  </section>

  <section class="pb-24 md:pb-32">
    <div class="container-x">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {posts.map((post, i) => (
          <Reveal delay={(i % 3) * 100}>
            <ArticleCard
              href={`/business-in-florida/${post.slug}/`}
              category={post.data.category}
              title={post.data.title}
              excerpt={post.data.description}
              date={formatDate(post.data.publishedAt)}
              readingTime={post.data.readingTime}
              gradient={post.data.gradient}
            />
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24" style="background: rgb(var(--surface));">
    <div class="container-x text-center max-w-2xl mx-auto">
      <Reveal>
        <span class="eyebrow">Newsletter</span>
        <h2 class="display-sm mt-6">Aggiornamenti, una volta al mese.</h2>
        <p class="mt-5 text-soft">Ricevi i nuovi articoli e gli aggiornamenti sul business in Florida. Niente spam.</p>
        <form class="mt-8 flex gap-2 max-w-md mx-auto flex-wrap" onsubmit="event.preventDefault(); alert('Iscrizione di esempio – collegare al provider email.');">
          <input type="email" required placeholder="La tua email" class="field-input flex-1 min-w-[200px]" />
          <button class="btn btn-primary px-5" type="submit">Iscriviti</button>
        </form>
        <p class="mt-4 text-[12px] text-muted">
          Iscrivendoti accetti la <a href="/privacy-policy/" class="link-underline">Privacy Policy</a>.
        </p>
      </Reveal>
    </div>
  </section>
</Layout>
