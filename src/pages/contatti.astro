---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';
import LeadForm from '../components/LeadForm.tsx';
---

<Layout title="Contatti | [NOME BRAND] – Company Setup in Florida" description="Compila il form per ricevere informazioni sul servizio di company setup in Florida. Risposta entro pochi giorni lavorativi.">

  <section class="pt-20 pb-12 md:pt-28">
    <div class="container-x">
      <nav class="text-[13px] text-muted mb-8">
        <a href="/" class="link-underline">Home</a> <span class="mx-2">/</span> <span>Contatti</span>
      </nav>
      <Reveal>
        <span class="eyebrow">Parliamone</span>
        <h1 class="display mt-7 max-w-3xl">Raccontaci il tuo <em>progetto</em>.</h1>
      </Reveal>
      <Reveal delay={150} class="mt-8 max-w-2xl text-soft text-[18px] leading-relaxed">
        <p>
          Compila il form per ricevere informazioni sul servizio. Ti rispondiamo entro <strong style="color: rgb(var(--ink-900));">[N] giorni lavorativi</strong>.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-x grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      <Reveal class="lg:col-span-7">
        <div class="rounded-3xl p-8 md:p-10" style="background: rgb(var(--bg)); border: 1px solid rgb(var(--line));">
          <LeadForm client:load />
        </div>
      </Reveal>

      <aside class="lg:col-span-5 space-y-5">
        <Reveal delay={120}>
          <div class="rounded-2xl p-7" style="background: rgb(var(--surface)); border: 1px solid rgb(var(--line));">
            <h3 class="font-serif text-xl mb-5">Recapiti diretti</h3>
            <div class="space-y-4">
              {[
                { icon: 'mail', label: 'Email', value: '[EMAIL]' },
                { icon: 'phone', label: 'Telefono', value: '[TELEFONO]' },
                { icon: 'pin', label: 'Sede operativa', value: '[INDIRIZZO IT]' },
                { icon: 'clock', label: 'Orari', value: 'Lun-Ven · 9:00–18:00 CET' },
              ].map((c, i, arr) => (
                <div class={`flex gap-4 items-start ${i < arr.length - 1 ? 'pb-4' : ''}`} style={i < arr.length - 1 ? 'border-bottom: 1px solid rgb(var(--line));' : ''}>
                  <span style="color: rgb(var(--accent)); flex-shrink: 0;">
                    {c.icon === 'mail' && (<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>)}
                    {c.icon === 'phone' && (<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>)}
                    {c.icon === 'pin' && (<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>)}
                    {c.icon === 'clock' && (<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>)}
                  </span>
                  <div>
                    <div class="text-[11px] uppercase tracking-[0.14em] text-muted">{c.label}</div>
                    <div class="mt-0.5 font-medium" style="color: rgb(var(--ink-900));">{c.value}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </Reveal>

        <Reveal delay={200}>
          <div class="rounded-2xl p-7" style="background: rgb(var(--ink-950)); color: rgb(var(--bg));">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: rgb(var(--accent));"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <h3 class="font-serif text-xl mt-4" style="color: rgb(var(--bg));">Nota importante</h3>
            <p class="mt-2 text-[14px] leading-relaxed" style="color: rgb(var(--ink-400));">
              L'invio del form non crea un rapporto professionale con [NOME BRAND], con il partner Florida o con qualunque professionista.
              Per maggiori informazioni consulta il <a href="/disclaimer/" style="color: rgb(var(--accent));" class="link-underline">Disclaimer</a>.
            </p>
          </div>
        </Reveal>
      </aside>
    </div>
  </section>
</Layout>
