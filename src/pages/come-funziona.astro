---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';

const steps = [
  { num: '01', title: 'Richiesta', text: 'Compili il form di contatto e indichi obiettivo, attività e tempi. È il modo più rapido per capirci e darti una prima risposta utile.' },
  { num: '02', title: 'Briefing', text: 'Il team italiano ti contatta entro [N] giorni lavorativi per allineare obiettivi, opzioni amministrative, tempi e costi del servizio.' },
  { num: '03', title: 'Raccolta documenti', text: 'Ti inviamo una checklist dei documenti richiesti (passaporto, dati anagrafici, indirizzi, struttura societaria). Verifichiamo che siano completi.' },
  { num: '04', title: 'Filing in Florida', text: 'Il partner Florida esegue il filing presso la Florida Division of Corporations e ti aggiorniamo a ogni passaggio.' },
  { num: '05', title: 'Consegna e operatività', text: 'Ricevi i documenti societari in formato digitale e una nota operativa con i passi successivi (EIN, conto bancario, adempimenti annuali).' },
];

const times = [
  { value: '1-2', unit: 'giorni', label: 'Risposta al primo contatto' },
  { value: '3-5', unit: 'giorni', label: 'Raccolta e verifica documenti' },
  { value: '5-15', unit: 'giorni', label: 'Filing presso Sunbiz' },
  { value: 'IRS', unit: 'variabili', label: 'Tempistiche EIN' },
];
---

<Layout
  title="Come funziona il Company Setup in Florida | [NOME BRAND]"
  description="Apertura company in Florida in 5 step: richiesta, briefing, raccolta documenti, filing tramite partner USA, consegna.">

  <section class="pt-20 pb-12 md:pt-28 mesh-accent">
    <div class="container-x">
      <nav class="text-[13px] text-muted mb-8">
        <a href="/" class="link-underline">Home</a> <span class="mx-2">/</span> <span>How it works</span>
      </nav>
      <Reveal>
        <span class="eyebrow">Il processo</span>
        <h1 class="display mt-7 max-w-3xl">Cinque passi, <em>ruoli chiari</em>.</h1>
      </Reveal>
      <Reveal delay={150} class="mt-8 max-w-2xl text-soft text-[19px] leading-relaxed">
        <p>
          Un percorso lineare con tempi indicativi e nessuna sorpresa. Tu segui il processo in italiano; il partner USA si occupa del filing.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="py-24">
    <div class="container-x max-w-4xl">
      {steps.map((step, i) => (
        <Reveal delay={i * 80}>
          <div class="grid grid-cols-12 gap-6 py-10" style={i < steps.length - 1 ? 'border-bottom: 1px solid rgb(var(--line));' : ''}>
            <div class="col-span-2 md:col-span-2 font-serif text-3xl md:text-4xl" style="color: rgb(var(--accent-deep));">
              {step.num}
            </div>
            <div class="col-span-10 md:col-span-10">
              <h2 class="font-serif text-2xl md:text-3xl">{step.title}</h2>
              <p class="mt-3 text-soft leading-relaxed max-w-2xl">{step.text}</p>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </section>

  <section class="py-24" style="background: rgb(var(--surface));">
    <div class="container-x">
      <Reveal class="max-w-2xl mb-14">
        <span class="eyebrow">Trasparenza</span>
        <h2 class="display-sm mt-6">Chi fa cosa.</h2>
        <p class="mt-5 text-soft text-[17px] leading-relaxed">
          Tre attori distinti, ruoli chiari. Nessuna confusione.
        </p>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <Reveal>
          <div class="card h-full">
            <span class="chapter-num">— 01</span>
            <h3 class="font-serif text-xl mt-4">[NOME BRAND] (Italia)</h3>
            <p class="mt-3 text-soft leading-relaxed text-[15px]">
              Coordinamento, comunicazione in italiano, raccolta documenti, gestione del rapporto con il partner Florida. Servizio amministrativo, non legale.
            </p>
          </div>
        </Reveal>
        <Reveal delay={120}>
          <div class="card h-full" style="background: rgb(var(--ink-950)); color: rgb(var(--bg)); border-color: rgb(var(--ink-950));">
            <span class="chapter-num" style="color: rgb(var(--accent));">— 02</span>
            <h3 class="font-serif text-xl mt-4" style="color: rgb(var(--bg));">[PARTNER FLORIDA]</h3>
            <p class="mt-3 leading-relaxed text-[15px]" style="color: rgb(var(--ink-400));">
              Filing presso la Florida Division of Corporations, servizio di registered agent, gestione di pratiche amministrative locali. Soggetto USA indipendente.
            </p>
          </div>
        </Reveal>
        <Reveal delay={240}>
          <div class="card h-full">
            <span class="chapter-num">— 03</span>
            <h3 class="font-serif text-xl mt-4">Professionisti terzi</h3>
            <p class="mt-3 text-soft leading-relaxed text-[15px]">
              Avvocati abilitati in Florida, CPA e commercialisti italiani per consulenza legale, fiscale o contabile. Su richiesta possiamo segnalare contatti, senza alcun obbligo.
            </p>
          </div>
        </Reveal>
      </div>

      <Reveal delay={350} class="mt-12 rounded-2xl p-7" style="background: rgb(var(--bg)); border: 1px solid rgb(var(--line));">
        <div class="flex gap-4 items-start">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: rgb(var(--accent)); flex-shrink: 0; margin-top: 2px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <div>
            <strong class="font-serif text-lg">Nota di trasparenza</strong>
            <p class="mt-2 text-soft leading-relaxed">
              [NOME BRAND] è il portale italiano. [PARTNER FLORIDA] è il soggetto statunitense indipendente che esegue il filing.
              L'invio di un form o la consultazione del sito <strong style="color: rgb(var(--ink-900));">non crea automaticamente</strong> un rapporto professionale con [NOME BRAND], con il partner Florida o con altri soggetti.
            </p>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <section class="py-24">
    <div class="container-x">
      <Reveal class="text-center max-w-xl mx-auto mb-14">
        <span class="eyebrow">Tempi indicativi</span>
        <h2 class="display-sm mt-6">Quanto serve.</h2>
        <p class="mt-5 text-soft">Variabili in base al carico della Florida Division of Corporations e alla completezza dei documenti.</p>
      </Reveal>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-px max-w-4xl mx-auto" style="background: rgb(var(--line));">
        {times.map((t, i) => (
          <Reveal delay={i * 80}>
            <div class="p-8 text-center" style="background: rgb(var(--bg));">
              <div class="font-serif text-4xl md:text-5xl" style="color: rgb(var(--ink-900));">{t.value}</div>
              <div class="mt-1 text-[11px] uppercase tracking-[0.14em] text-muted">{t.unit}</div>
              <div class="mt-4 text-sm text-soft leading-snug">{t.label}</div>
            </div>
          </Reveal>
        ))}
      </div>

      <p class="mt-8 text-center text-[13px] text-muted max-w-2xl mx-auto leading-relaxed">
        I tempi indicati sono medi e <strong style="color: rgb(var(--ink-800));">non costituiscono garanzia di esito</strong>. Comunichiamo le tempistiche stimate prima di iniziare.
      </p>
    </div>
  </section>

  <section class="py-24" style="background: rgb(var(--ink-950)); color: rgb(var(--bg));">
    <div class="container-x text-center max-w-3xl mx-auto">
      <Reveal>
        <h2 class="display-sm" style="color: rgb(var(--bg));">Pronto a iniziare?</h2>
        <p class="mt-5 text-[17px]" style="color: rgb(var(--ink-400));">
          Raccontaci il progetto: ti risponderemo con un quadro chiaro di opzioni, tempi e costi.
        </p>
        <a href="/contatti/" class="btn btn-accent mt-8 px-6 py-3.5">Richiedi informazioni</a>
      </Reveal>
    </div>
  </section>
</Layout>
