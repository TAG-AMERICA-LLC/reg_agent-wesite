---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';
---

<Layout title="Pagina non trovata | [NOME BRAND]" description="La pagina che cercavi non esiste." noindex={true}>
  <section class="py-32 md:py-40">
    <div class="container-x text-center max-w-2xl mx-auto">
      <Reveal>
        <div class="font-serif text-[10rem] leading-none" style="color: rgb(var(--accent-deep));">404</div>
        <h1 class="display-sm mt-4">Pagina non trovata.</h1>
        <p class="mt-5 text-soft text-[17px]">
          La pagina che cercavi non esiste o è stata spostata. Puoi tornare alla home o consultare le FAQ.
        </p>
        <div class="mt-8 flex justify-center gap-3 flex-wrap">
          <a href="/" class="btn btn-primary px-6 py-3">Torna alla home</a>
          <a href="/faq/" class="btn btn-outline px-6 py-3">Consulta le FAQ</a>
        </div>
      </Reveal>
    </div>
  </section>
</Layout>
