---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';

const tiers = [
  {
    name: 'Starter',
    tagline: 'Filing essenziale',
    price: '[PREZZO BASE]',
    featured: false,
    features: [
      'Filing LLC presso Sunbiz (via partner USA)',
      'Registered Agent in Florida – 1° anno',
      'Consegna Articles of Organization (digitale)',
      'Supporto operativo in italiano',
    ],
  },
  {
    name: 'Plus',
    tagline: 'Filing + operatività',
    price: '[PREZZO]',
    featured: true,
    badge: 'Consigliato',
    features: [
      'Tutto il pacchetto Starter',
      'Richiesta EIN presso IRS',
      'Template di Operating Agreement',
      'Sessione di onboarding di 30 minuti',
      'Checklist post-setup personalizzata',
    ],
  },
  {
    name: 'Full',
    tagline: 'Setup completo',
    price: '[PREZZO]',
    featured: false,
    features: [
      'Tutto il pacchetto Plus',
      'Supporto per apertura conto bancario USA',
      'Consegna documenti certificati',
      'Supporto esteso (90 giorni)',
      'Reminder annuali su scadenze societarie',
    ],
  },
];
---

<Layout
  title="Pacchetti e prezzi – Company Setup in Florida | [NOME BRAND]"
  description="Pacchetti chiari per aprire una LLC o Corporation in Florida. Servizio amministrativo e registered agent tramite partner USA.">

  <section class="pt-20 pb-12 md:pt-28">
    <div class="container-x">
      <nav class="text-[13px] text-muted mb-8">
        <a href="/" class="link-underline">Home</a> <span class="mx-2">/</span>
        <a href="/company-setup-florida/" class="link-underline">Company Setup</a> <span class="mx-2">/</span>
        <span>Pacchetti</span>
      </nav>
      <Reveal>
        <span class="eyebrow">Listino</span>
        <h1 class="display mt-7 max-w-3xl">Pacchetti e <em>prezzi</em>.</h1>
      </Reveal>
      <Reveal delay={150} class="mt-8 max-w-2xl text-soft text-[18px] leading-relaxed">
        <p>
          Tre opzioni chiare. I prezzi riguardano il servizio amministrativo di [NOME BRAND] e del partner Florida.
          Le fees governative variabili applicate dalla Florida Division of Corporations e gli eventuali costi di terzi sono esclusi.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {tiers.map((t, i) => (
          <Reveal delay={i * 100}>
            <div class={`relative h-full rounded-3xl p-8 flex flex-col ${t.featured ? 'shadow-2xl' : ''}`}
              style={t.featured
                ? 'background: rgb(var(--ink-950)); color: rgb(var(--bg));'
                : 'background: rgb(var(--bg)); border: 1px solid rgb(var(--line));'}>

              {t.badge && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full px-3 py-1 text-[11px] font-medium uppercase tracking-[0.14em]"
                  style="background: rgb(var(--accent)); color: white;">
                  {t.badge}
                </span>
              )}

              <span class={`text-[11px] uppercase tracking-[0.14em] ${t.featured ? '' : 'text-soft'}`}
                style={t.featured ? 'color: rgb(var(--accent));' : ''}>{t.name}</span>
              <h3 class={`font-serif text-2xl mt-2 ${t.featured ? '' : ''}`}
                style={t.featured ? 'color: rgb(var(--bg));' : ''}>{t.tagline}</h3>

              <div class="mt-6 mb-2">
                <span class={`text-[12px] ${t.featured ? '' : 'text-muted'}`}
                  style={t.featured ? 'color: rgb(var(--ink-400));' : ''}>da</span>
                <div class="font-serif text-5xl mt-1" style={t.featured ? 'color: rgb(var(--bg));' : ''}>{t.price}</div>
                <span class={`text-sm ${t.featured ? '' : 'text-muted'}`}
                  style={t.featured ? 'color: rgb(var(--ink-400));' : ''}>[VALUTA] · servizio amministrativo</span>
              </div>

              <ul class="mt-8 space-y-3 flex-1">
                {t.features.map((f) => (
                  <li class="flex items-start gap-3 text-[14.5px] leading-relaxed">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style={`flex-shrink: 0; margin-top: 4px; color: ${t.featured ? 'rgb(var(--accent))' : 'rgb(var(--accent))'};`}>
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    <span style={t.featured ? 'color: rgb(var(--ink-400));' : 'color: rgb(var(--ink-800));'}>{f}</span>
                  </li>
                ))}
              </ul>

              <a href="/contatti/" class={`mt-8 w-full justify-center btn ${t.featured ? 'btn-accent' : 'btn-outline'}`}>
                Richiedi informazioni
              </a>
            </div>
          </Reveal>
        ))}
      </div>

      <Reveal delay={350} class="mt-12 rounded-3xl p-8" style="background: rgb(var(--surface)); border: 1px solid rgb(var(--line));">
        <h3 class="font-serif text-2xl">Sempre escluso</h3>
        <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2 text-[14.5px] text-soft">
          <span>• Consulenza legale, fiscale o contabile (italiana o USA).</span>
          <span>• Dichiarazioni fiscali, contabilità, payroll.</span>
          <span>• Fees governative variabili (Sunbiz, IRS).</span>
          <span>• Costi di terzi (banca, traduzioni, notarizzazioni).</span>
        </div>
        <p class="mt-5 text-[13px] text-muted leading-relaxed">
          I prezzi sono indicativi e possono variare in base alla complessità della pratica. Confermeremo il preventivo definitivo prima di iniziare le attività. Eventuali consulenze legali o fiscali sono escluse e, se necessarie, sono fornite da professionisti terzi.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="py-24 md:py-32" style="background: rgb(var(--ink-950)); color: rgb(var(--bg));">
    <div class="container-x text-center max-w-3xl mx-auto">
      <Reveal>
        <h2 class="display-sm" style="color: rgb(var(--bg));">Hai un'esigenza particolare?</h2>
        <p class="mt-5 text-[17px] leading-relaxed" style="color: rgb(var(--ink-400));">
          Strutture multi-membro, holding, presenza di soci stranieri non italiani: ti rispondiamo con un'analisi del caso e un preventivo personalizzato.
        </p>
        <a href="/contatti/" class="btn btn-accent mt-8 px-6 py-3.5">Parla con noi</a>
      </Reveal>
    </div>
  </section>
</Layout>
