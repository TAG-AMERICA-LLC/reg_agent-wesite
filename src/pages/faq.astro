---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';
import FAQ from '../components/FAQ.tsx';

const groups = [
  {
    title: 'Servizio',
    items: [
      { q: 'Cosa fa esattamente [NOME BRAND]?', a: '[NOME BRAND] è un portale italiano che offre un servizio amministrativo di company setup in Florida. Coordina la raccolta documenti, la comunicazione in italiano e l\'interfaccia con il partner statunitense che esegue il filing. Non fornisce consulenza legale, fiscale o contabile.' },
      { q: 'Siete uno studio legale?', a: 'No. [NOME BRAND] non è uno studio legale e non eroga consulenza legale, fiscale o contabile. Su richiesta possiamo segnalare professionisti abilitati, senza alcun obbligo.' },
      { q: 'In che lingua lavorate?', a: 'Tutta la comunicazione con [NOME BRAND] è in italiano. I documenti societari della Florida Division of Corporations sono ovviamente in inglese.' },
    ],
  },
  {
    title: 'Tempi e costi',
    items: [
      { q: 'Quanto tempo serve per aprire una LLC in Florida?', a: 'I tempi medi indicativi vanno da pochi giorni lavorativi a qualche settimana, in base al carico della Florida Division of Corporations e alla completezza dei documenti.' },
      { q: 'Quanto costa il servizio?', a: 'I prezzi base del servizio amministrativo sono indicati nei pacchetti. Sono escluse fees governative variabili e costi di terzi. Confermeremo il preventivo definitivo prima di iniziare.' },
      { q: 'I prezzi includono le tasse statali e federali?', a: 'No. I prezzi del servizio non includono fees governative (es. filing fee Sunbiz), imposte statali o federali, né eventuali costi di terzi (es. banche, traduzioni).' },
    ],
  },
  {
    title: 'Documenti',
    items: [
      { q: 'Quali documenti mi servono per iniziare?', a: 'Tipicamente: passaporto valido, dati anagrafici completi, indirizzo di residenza, dati su struttura societaria desiderata. Ti inviamo una checklist personalizzata dopo il primo contatto.' },
      { q: 'Devo venire in Florida per aprire la società?', a: 'In genere il filing può essere completato a distanza. L\'apertura di un conto bancario può richiedere la presenza fisica negli USA: dipende dalla banca scelta e le condizioni cambiano spesso.' },
      { q: 'Posso aprire una company se vivo fuori dall\'Italia?', a: 'Generalmente sì. La normativa Florida non richiede la residenza italiana per costituire una società. Verifica però gli aspetti fiscali e di compliance del tuo paese di residenza con un commercialista locale.' },
    ],
  },
  {
    title: 'Partner Florida',
    items: [
      { q: 'Chi è il partner Florida?', a: 'È un soggetto statunitense indipendente che esegue il filing presso la Florida Division of Corporations e fornisce il servizio di registered agent.' },
      { q: 'Chi esegue materialmente il filing?', a: 'Il filing è eseguito dal partner [PARTNER FLORIDA] o da un soggetto da esso incaricato.' },
      { q: 'Il contatto con il partner crea un rapporto professionale?', a: 'No. L\'invio di un form o il contatto iniziale non crea automaticamente un rapporto professionale con [NOME BRAND], con il partner Florida o con altri soggetti.' },
    ],
  },
  {
    title: 'Limiti e ambito',
    items: [
      { q: 'Mi date consigli su quale forma societaria scegliere?', a: 'No. La scelta della forma societaria dipende da elementi legali e fiscali personali. Per una valutazione del tuo caso occorre rivolgersi a un avvocato e/o a un commercialista abilitati.' },
      { q: 'Posso ricevere una consulenza legale o fiscale tramite il sito?', a: 'No. [NOME BRAND] non è uno studio legale e non fornisce consulenza. Su richiesta possiamo segnalare professionisti abilitati, senza alcun obbligo.' },
      { q: 'I miei dati vengono trasferiti negli USA?', a: 'Sì, per l\'esecuzione del servizio è necessario condividere alcuni dati con il partner statunitense. I dettagli sono nella Privacy Policy.' },
    ],
  },
];
---

<Layout title="FAQ – Aprire una Company in Florida | [NOME BRAND]" description="Risposte alle domande più frequenti sul servizio di company setup in Florida: tempi, costi, documenti, ruolo del partner USA.">

  <section class="pt-20 pb-12 md:pt-28">
    <div class="container-x">
      <nav class="text-[13px] text-muted mb-8">
        <a href="/" class="link-underline">Home</a> <span class="mx-2">/</span> <span>FAQ</span>
      </nav>
      <Reveal>
        <span class="eyebrow">FAQ</span>
        <h1 class="display mt-7 max-w-3xl">Le domande <em>più frequenti</em>.</h1>
      </Reveal>
      <Reveal delay={150} class="mt-8 max-w-2xl text-soft text-[18px] leading-relaxed">
        <p>
          Quelle che ci vengono fatte più spesso. Contenuti informativi: per il tuo caso specifico è sempre consigliata una valutazione professionale.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-x grid grid-cols-1 lg:grid-cols-12 gap-12">
      <aside class="lg:col-span-3">
        <div class="sticky top-28">
          <div class="text-[11px] uppercase tracking-[0.14em] text-muted mb-4">Sezioni</div>
          <ul class="space-y-2.5 text-[14.5px]">
            {groups.map((g) => (
              <li><a href={`#${g.title.toLowerCase().replace(/\s/g, '-')}`} class="link-underline" style="color: rgb(var(--ink-800));">{g.title}</a></li>
            ))}
          </ul>
        </div>
      </aside>

      <div class="lg:col-span-9 space-y-16">
        {groups.map((g) => (
          <div id={g.title.toLowerCase().replace(/\s/g, '-')}>
            <Reveal>
              <h2 class="font-serif text-3xl mb-2">{g.title}</h2>
              <div class="divider mb-2"></div>
            </Reveal>
            <FAQ items={g.items} client:visible />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24" style="background: rgb(var(--surface));">
    <div class="container-x text-center max-w-2xl mx-auto">
      <Reveal>
        <h2 class="display-sm">Non hai trovato la risposta?</h2>
        <p class="mt-5 text-soft text-[17px]">Scrivici: ti rispondiamo entro pochi giorni lavorativi.</p>
        <a href="/contatti/" class="btn btn-primary mt-8 px-6 py-3.5">Contattaci</a>
      </Reveal>
    </div>
  </section>
</Layout>
