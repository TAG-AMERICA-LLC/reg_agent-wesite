---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Reveal from '../components/Reveal.astro';
import FAQ from '../components/FAQ.tsx';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
).slice(0, 3);

const formatDate = (d: Date) =>
  new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

const homeFaqs = [
  { q: 'Quanto tempo serve per aprire una LLC in Florida?', a: 'I tempi indicativi vanno da pochi giorni lavorativi a qualche settimana, in base al carico della Florida Division of Corporations e alla completezza dei documenti. Comunichiamo i tempi stimati prima di iniziare.' },
  { q: 'Devo venire in Florida per aprire la società?', a: 'In genere il filing può essere completato a distanza. L\'apertura di un conto bancario può richiedere la presenza fisica negli USA: le condizioni dipendono dall\'istituto e cambiano spesso.' },
  { q: 'Mi date consigli su quale forma societaria scegliere?', a: 'No. La scelta dipende da elementi legali e fiscali personali. Per una valutazione del tuo caso occorre rivolgersi a un avvocato e/o a un commercialista abilitati.' },
  { q: 'Chi esegue materialmente il filing?', a: 'Il filing presso la Florida Division of Corporations è eseguito dal nostro partner [PARTNER FLORIDA] o da un soggetto da esso incaricato.' },
];
---

<Layout
  title="Aprire una Company in Florida dall'Italia | [NOME BRAND]"
  description="Servizio amministrativo per aprire una LLC o Corporation in Florida. Filing eseguito dal nostro partner USA. Assistenza in italiano.">

  <Hero />

  <Marquee />

  <!-- ============ Manifesto teaser ============ -->
  <section class="py-28 md:py-40">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-8">
        <Reveal class="col-span-12 md:col-span-3">
          <span class="chapter">— Capitolo 01</span>
          <div class="mt-3 text-[12px] uppercase tracking-[0.18em] text-ink-mute">Manifesto</div>
        </Reveal>
        <Reveal delay={150} class="col-span-12 md:col-span-9">
          <p class="display-md max-w-[22ch]">
            Crediamo che aprire una società all'estero <em>non debba essere complicato</em>. Solo lo strettamente necessario, fatto bene.
          </p>
          <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
            <div>
              <span class="chapter">— 01</span>
              <h3 class="mt-3 font-serif text-2xl">Italiano per davvero</h3>
              <p class="mt-2 text-ink-soft leading-relaxed text-[15px]">Niente Google Translate. Briefing, documenti e supporto interamente in italiano.</p>
            </div>
            <div>
              <span class="chapter">— 02</span>
              <h3 class="mt-3 font-serif text-2xl">Trasparenza dei ruoli</h3>
              <p class="mt-2 text-ink-soft leading-relaxed text-[15px]">Noi coordiniamo dall'Italia. Il partner USA esegue il filing. Non confondiamo le carte.</p>
            </div>
            <div>
              <span class="chapter">— 03</span>
              <h3 class="mt-3 font-serif text-2xl">Solo amministrativo</h3>
              <p class="mt-2 text-ink-soft leading-relaxed text-[15px]">Non siamo uno studio legale. Per consulenze ti indirizziamo a professionisti abilitati.</p>
            </div>
          </div>
          <a href="/manifesto/" class="btn btn-ghost mt-12 px-0 btn-arrow">
            Leggi il manifesto completo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </Reveal>
      </div>
    </div>
  </section>

  <div class="rule"></div>

  <!-- ============ Il servizio in oggetti ============ -->
  <section class="py-28 md:py-40 relative grain" style="background: rgb(var(--paper-deep));">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-8">
        <Reveal class="col-span-12 md:col-span-5">
          <span class="chapter">— Capitolo 02</span>
          <h2 class="display-md mt-6">
            Un servizio <em>amministrativo</em>, chiaro e moderno.
          </h2>
          <p class="mt-7 text-[17px] leading-relaxed text-ink-soft max-w-md">
            Coordiniamo per te le attività necessarie ad aprire una company in Florida.
            Non forniamo consulenza legale o fiscale: ci occupiamo della parte operativa e dell'interfaccia con il partner statunitense.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href="/company-setup-florida/" class="btn btn-primary px-6 py-3 btn-arrow">
              Scopri il servizio
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="/company-setup-florida/pacchetti/" class="btn btn-ghost px-3">Vedi pacchetti →</a>
          </div>
        </Reveal>

        <div class="col-span-12 md:col-span-7 md:pl-8">
          {[
            { label: 'Verifica preliminare di dati e documenti', tag: 'Onboarding' },
            { label: 'Coordinamento del filing con il partner Florida', tag: 'Filing' },
            { label: 'Servizio di registered agent tramite partner', tag: 'Agent' },
            { label: 'Consegna digitale dei documenti societari', tag: 'Delivery' },
            { label: 'Indicazioni operative sui passi successivi', tag: 'After' },
          ].map((it, i) => (
            <Reveal delay={i * 80}>
              <div class="grid grid-cols-12 gap-4 items-baseline py-5"
                style={`border-top: 1px solid rgb(var(--hairline)); ${i === 4 ? 'border-bottom: 1px solid rgb(var(--hairline));' : ''}`}>
                <div class="col-span-2 chapter">— {String(i + 1).padStart(2, '0')}</div>
                <div class="col-span-7 text-[17px] text-ink leading-snug">{it.label}</div>
                <div class="col-span-3 text-right"><span class="chip">{it.tag}</span></div>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Il processo (5 step orizzontali editoriali) ============ -->
  <section class="py-28 md:py-40">
    <div class="container-x">
      <Reveal class="max-w-3xl">
        <span class="chapter">— Capitolo 03</span>
        <h2 class="display-md mt-6">Cinque passaggi.<br/>Ruoli <em>chiari</em>.</h2>
      </Reveal>

      <div class="mt-20 grid grid-cols-12 gap-8 md:gap-12">
        {[
          { title: 'Richiesta', text: 'Compili il form. Ci spieghi obiettivo, attività, tempi.' },
          { title: 'Briefing', text: 'Ti chiamiamo per allineare opzioni, costi e tempi, in italiano.' },
          { title: 'Documenti', text: 'Inviamo la checklist, verifichiamo che sia tutto in ordine.' },
          { title: 'Filing', text: 'Il partner Florida esegue il filing presso la Florida Division of Corporations.' },
          { title: 'Operatività', text: 'Ricevi i documenti e le indicazioni sui passi successivi.' },
        ].map((step, i) => (
          <Reveal delay={i * 90} class="col-span-12 md:col-span-6 lg:col-span-4 xl:col-span-4">
            <div class="pt-8 pb-2" style="border-top: 1px solid rgb(var(--hairline));">
              <div class="flex items-baseline justify-between">
                <span class="num-display text-clay-deep" style="font-size: clamp(2.4rem, 4.5vw, 3.5rem);">{String(i + 1).padStart(2, '0')}</span>
                <span class="chapter">{step.title}</span>
              </div>
              <p class="mt-6 text-ink-soft leading-relaxed text-[15.5px] max-w-xs">{step.text}</p>
            </div>
          </Reveal>
        ))}
      </div>

      <div class="mt-16 text-center">
        <a href="/come-funziona/" class="btn btn-outline px-6 py-3 btn-arrow">
          Vedi i dettagli del processo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ LLC vs Corp ============ -->
  <section class="py-28 md:py-40" style="background: rgb(var(--paper-deep));">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-8 items-end">
        <Reveal class="col-span-12 md:col-span-6">
          <span class="chapter">— Capitolo 04</span>
          <h2 class="display-md mt-6">LLC o <em>Corporation</em>?</h2>
        </Reveal>
        <Reveal delay={120} class="col-span-12 md:col-span-6">
          <p class="text-[17px] leading-relaxed text-ink-soft max-w-md md:ml-auto">
            Le due forme societarie più diffuse in Florida. Le presentiamo in modo informativo.
            La scelta nel tuo caso specifico richiede una valutazione professionale.
          </p>
        </Reveal>
      </div>

      <div class="mt-16 grid grid-cols-12 gap-px" style="background: rgb(var(--hairline-hard));">
        <div class="col-span-12 md:col-span-3 p-6 bg-paper-deep">
          <span class="chip">Caratteristica</span>
        </div>
        <div class="col-span-6 md:col-span-4 lg:col-span-4 p-6 bg-paper-deep">
          <span class="chip chip-dot">LLC</span>
        </div>
        <div class="col-span-6 md:col-span-5 lg:col-span-5 p-6 bg-paper-deep">
          <span class="chip">Corporation</span>
        </div>

        {[
          ['Struttura tipica', 'Snella, flessibile', 'Più strutturata'],
          ['Soci / Membri', 'Members', 'Shareholders'],
          ['Uso ricorrente', 'Piccole attività, holding', 'Startup, raccolta capitali'],
          ['Documento istitutivo', 'Articles of Organization', 'Articles of Incorporation'],
          ['Adempimenti tipici', 'Minori', 'Maggiori'],
        ].map((row, i) => (
          <>
            <div class="col-span-12 md:col-span-3 p-6 bg-paper-deep text-ink-mute text-[14px]">{row[0]}</div>
            <div class="col-span-6 md:col-span-4 lg:col-span-4 p-6 bg-paper-deep font-serif text-[18px] text-ink"
              style="font-variation-settings: 'SOFT' 35, 'opsz' 60;">{row[1]}</div>
            <div class="col-span-6 md:col-span-5 lg:col-span-5 p-6 bg-paper-deep font-serif text-[18px] text-ink"
              style="font-variation-settings: 'SOFT' 35, 'opsz' 60;">{row[2]}</div>
          </>
        ))}
      </div>

      <p class="mt-8 text-[13px] text-ink-mute leading-relaxed max-w-3xl">
        <strong class="text-ink">Nota informativa:</strong> la scelta della forma societaria dipende da molti fattori personali, fiscali e operativi.
        Per una valutazione del tuo caso specifico è necessario rivolgersi a professionisti abilitati nelle giurisdizioni rilevanti.
      </p>
    </div>
  </section>

  <!-- ============ Partner Florida ============ -->
  <section class="py-28 md:py-40">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-8 items-center">
        <Reveal class="col-span-12 md:col-span-6 order-2 md:order-1">
          <span class="chapter">— Capitolo 05</span>
          <h2 class="display-md mt-6 max-w-[18ch]">Un partner locale.<br/><em>Indipendente</em>.</h2>
          <p class="mt-7 text-[17px] leading-relaxed text-ink-soft max-w-md">
            In Florida ogni società deve indicare un registered agent con indirizzo fisico nello Stato.
            Riceve atti ufficiali e comunicazioni legali per conto della società. Il nostro partner offre questo servizio
            e gestisce il filing presso la Florida Division of Corporations.
          </p>
          <a href="/registered-agent/" class="btn btn-primary mt-10 px-6 py-3.5 btn-arrow">
            Scopri il partner
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </Reveal>

        <Reveal delay={150} class="col-span-12 md:col-span-6 order-1 md:order-2">
          <div class="card-dark p-10 md:p-12 relative overflow-hidden">
            <div class="absolute -top-32 -right-32 w-80 h-80 rounded-full" style="background: radial-gradient(circle, rgb(var(--clay) / 0.4), transparent 60%); filter: blur(40px);"></div>
            <div class="relative">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: rgb(var(--clay));"><path d="M12 22s8-7 8-13a8 8 0 0 0-16 0c0 6 8 13 8 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
              <h3 class="font-serif mt-8 leading-[1.1]"
                style="font-size: clamp(2rem, 4vw, 3rem); font-variation-settings: 'SOFT' 35, 'opsz' 96;">
                Registered Agent<br/>in Florida
              </h3>
              <p class="mt-4 text-[15px] leading-relaxed" style="color: rgb(var(--paper) / 0.7);">
                Obbligatorio per ogni LLC e Corporation costituita in Florida.
              </p>
              <div class="mt-10 rounded-xl p-5" style="background: rgb(var(--paper) / 0.06); box-shadow: inset 0 0 0 1px rgb(var(--paper) / 0.08);">
                <div class="text-[11px] uppercase tracking-[0.16em]" style="color: rgb(var(--clay));">Servizio fornito da</div>
                <div class="mt-2 font-serif text-xl">[PARTNER FLORIDA]</div>
                <div class="mt-1 text-[13.5px]" style="color: rgb(var(--paper) / 0.6);">Soggetto statunitense indipendente</div>
              </div>
            </div>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ============ Editoriale (3 articoli) ============ -->
  <section class="py-28 md:py-40" style="background: rgb(var(--paper-deep));">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-8 items-end mb-16">
        <Reveal class="col-span-12 md:col-span-8">
          <span class="chapter">— Capitolo 06</span>
          <h2 class="display-md mt-6 max-w-[20ch]">
            Capire come funziona il <em>business in Florida</em>.
          </h2>
        </Reveal>
        <Reveal delay={120} class="col-span-12 md:col-span-4 md:text-right">
          <a href="/business-in-florida/" class="btn btn-outline btn-arrow px-6 py-3">
            Tutti gli articoli
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </Reveal>
      </div>

      <div>
        {posts.map((p, i) => (
          <Reveal delay={i * 80}>
            <a href={`/business-in-florida/${p.slug}/`} class="group block py-8" style={`border-top: 1px solid rgb(var(--hairline)); ${i === posts.length - 1 ? 'border-bottom: 1px solid rgb(var(--hairline));' : ''}`}>
              <div class="grid grid-cols-12 gap-6 items-baseline">
                <div class="col-span-2 md:col-span-1 chapter">— {String(i + 1).padStart(2, '0')}</div>
                <div class="col-span-10 md:col-span-2"><span class="chip">{p.data.category}</span></div>
                <div class="col-span-12 md:col-span-7">
                  <h3 class="font-serif text-2xl md:text-[28px] leading-[1.15] text-ink"
                    style="font-variation-settings: 'SOFT' 35, 'opsz' 72;">
                    <span class="link-underline">{p.data.title}</span>
                  </h3>
                  <p class="mt-3 text-[15px] text-ink-soft leading-relaxed max-w-2xl">{p.data.description}</p>
                </div>
                <div class="col-span-12 md:col-span-2 md:text-right">
                  <div class="text-[12.5px] text-ink-mute">{formatDate(p.data.publishedAt)}</div>
                  <div class="text-[12px] text-ink-faint mt-1">{p.data.readingTime}</div>
                </div>
              </div>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="py-28 md:py-40">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-8 mb-16">
        <Reveal class="col-span-12 md:col-span-4">
          <span class="chapter">— Capitolo 07</span>
          <h2 class="display-md mt-6">Domande<br/><em>frequenti</em>.</h2>
          <p class="mt-7 text-ink-soft leading-relaxed max-w-xs text-[15.5px]">
            Quelle che ci vengono fatte più spesso. Per il resto, scrivici.
          </p>
          <a href="/faq/" class="btn btn-ghost mt-8 px-0 btn-arrow">
            Tutte le FAQ
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </Reveal>
        <Reveal delay={150} class="col-span-12 md:col-span-8">
          <FAQ items={homeFaqs} client:visible />
        </Reveal>
      </div>
    </div>
  </section>
</Layout>
