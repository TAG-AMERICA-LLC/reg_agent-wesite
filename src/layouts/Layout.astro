---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.tsx';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description, noindex, ogImage = '/og-default.svg' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fffdfa" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0c0e14" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme bootstrap prima del render per evitare flash -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const dark = stored === 'dark' || (!stored && prefers);
          if (dark) document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>

    <ViewTransitions />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner client:idle />

    <script>
      // Reveal-on-scroll: aggiunge .is-visible quando l'elemento entra nel viewport
      const init = () => {
        const els = document.querySelectorAll('[data-reveal]');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              const el = e.target as HTMLElement;
              const delay = el.dataset.revealDelay;
              if (delay) el.style.transitionDelay = `${delay}ms`;
              el.classList.add('is-visible');
              io.unobserve(el);
            }
          });
        }, { rootMargin: '0px 0px -80px 0px', threshold: 0.05 });
        els.forEach((el) => io.observe(el));
      };
      init();
      document.addEventListener('astro:after-swap', init);
    </script>
  </body>
</html>
